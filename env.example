# DijkFood — copy to `.env` in this folder and replace placeholders.
#
# ACCOUNT_ID: aws sts get-caller-identity --query Account --output text
# Role names vary by lab; common first-run ECS names are shown below.

# Region for boto3 and deploy
AWS_REGION=us-east-1

# Optional: container CLI for ECR build/push (default: docker). Use podman if Docker is not installed.
# DOCKER_CMD=podman

# Lab-preprovisioned ECS task roles (replace ACCOUNT_ID; adjust role names if your lab differs)
EXECUTION_ROLE_ARN=arn:aws:iam::ACCOUNT_ID:role/LabRole
TASK_ROLE_ARN=arn:aws:iam::ACCOUNT_ID:role/LabRole

# Optional: reuse the same RDS password on each deploy (otherwise deploy generates one)
# DIJKFOOD_DB_PASSWORD=your-secure-password

# Optional: run the FastAPI app locally (uvicorn) against RDS
# DB_HOST=your-rds-endpoint.rds.amazonaws.com
# DB_PORT=5432
# DB_NAME=dijkfood
# DB_USER=dijkfood_admin
# DB_PASSWORD=

# DynamoDB table names are injected by ECS; only needed for local API + Dynamo testing
# DYNAMODB_ORDER_LOGS_TABLE=
# DYNAMODB_COURIER_POSITIONS_TABLE=

# Routing graph S3 cache: set by deploy.py in connection.env / ECS (omit locally for OSM-only loads)
# ROUTING_GRAPH_S3_BUCKET=

# Optional: default URL for simulator scripts when you omit --base-url
# BASE_URL=http://your-alb-1234567890.us-east-1.elb.amazonaws.com

# Optional: ordering service calls routing at this base URL (ECS sets it to the same ALB)
# ROUTING_BASE_URL=http://localhost:8001

# Optional: tracking base URL for simulator services (defaults to BASE_URL + /tracking)
# TRACKING_BASE_URL=http://your-alb-1234567890.us-east-1.elb.amazonaws.com/tracking

# Agent + Bedrock: separate account — see .env.agent.example and deploy_agent.py (not deploy.py)

# Optional simulator service tuning (used by deploy_simulation.py and simulator CLIs)
# SIM_ORDERS_PER_SECOND=2
# SIM_DISCOVERY_INTERVAL_MS=2000
# SIM_POSITION_INTERVAL_MS=100
# SIM_POSITION_PARALLEL=32
# SIM_STATUS_INTERVAL_MS=100
# SIM_STATUS_PARALLEL=24
