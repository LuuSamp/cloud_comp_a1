# DijkFood agent — copy to `.env.agent` (Bedrock credits account API keys only).
# Do not commit `.env.agent` (contains secrets).
#
# Used by `python deploy.py --with-agent` to inject BEDROCK_* on the lab ECS task.
# All infra (ECS, ALB, DynamoDB sessions) stays on Learner Lab — see env.example for lab roles.
#
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional temporary credentials:
# AWS_SESSION_TOKEN=

AWS_REGION=us-east-1

# Bedrock model (enable in console for the credits account)
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0

# Optional tuning (controls cost)
AGENT_MAX_TOOL_ROUNDS=5
# AGENT_MAX_OUTPUT_TOKENS=2048
# Token budgets for the monitoring UI (set to your credit limit)
# AGENT_USAGE_BUDGET_TOKENS=500000
# AGENT_USAGE_DAILY_BUDGET_TOKENS=50000
# CloudWatch lookback for /v1/usage token totals (default 7)
# AGENT_USAGE_HISTORY_DAYS=7
#
# IAM on the Bedrock credits account (for Converse + usage monitoring):
#   bedrock:Converse, bedrock:InvokeModel (on your model)
#   cloudwatch:GetMetricData
AGENT_DESIRED_COUNT=1
# AGENT_ENABLED_TOOLS=get_order,get_order_history,list_order_statuses
# AGENT_CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
